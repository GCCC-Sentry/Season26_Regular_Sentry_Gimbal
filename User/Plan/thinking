// 在Gimbal_Controller()中临时修改
void Gimbal_Controller()
{
    static uint8_t first_run = 1;
    static float fixed_target_motor = 0.0f;

    if (Global.Control.mode != LOCK)
    {
        // 第一次运行时，记录当前电机位置作为固定目标
