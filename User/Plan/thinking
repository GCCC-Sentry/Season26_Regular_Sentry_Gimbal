```c
// 在Gimbal.c中添加辅助函数
/**
 * @brief 线性插值函数
 */
float linear_interpolate(float x, float x0, float x1, float y0, float y1)
{
    if (x1 == x0) return y0;
    return y0 + (y1 - y0) * (x - x0) / (x1 - x0);
}

/**
 * @brief 根据实测数据计算重力补偿
 * @param pitch_angle_rad pitch角度（弧度）
 * @return 重力补偿力矩
 */
float get_gravity_compensation_table(float pitch_angle_rad)
{
    float pitch_deg = rad2degree(pitch_angle_rad);

    // 实测标定数据（需要通过实验获得）
    // 方法：在不同角度下，记录维持静止所需的MIT前馈力矩
    const int num_points = 7;
    const float angles[7] = {-30.0f, -15.0f, 0.0f, 15.0f, 30.0f, 45.0f, 60.0f};
    const float torques[7] = {0.35f, 0.38f, 0.40f, 0.38f, 0.35f, 0.28f, 0.20f};  // 需要实测！

    // 边界处理
    if (pitch_deg <= angles[0]) return torques[0];
    if (pitch_deg >= angles[num_points-1]) return torques[num_points-1];

    // 查找插值区间
    for (int i = 0; i < num_points - 1; i++)
    {
        if (pitch_deg >= angles[i] && pitch_deg <= angles[i+1])
        {
            return linear_interpolate(pitch_deg, angles[i], angles[i+1], torques[i], torques[i+1]);
        }
    }

    return 0.4f;  // 默认值
}

// 在Gimbal_Controller()中（约275行）修改为：
Gimbal.pitch.gravity_compensation = get_gravity_compensation_table(Gimbal.pitch.pitch_location_now);
