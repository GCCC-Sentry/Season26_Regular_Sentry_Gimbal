        float motor_pos_init = pitch_motor_data.motor_data.para.pos;
        float imu_pos_init = Gimbal.pitch.pitch_location_now;

        // 计算offset（确保方向一致）
        // 方法：手动抬起pitch，观察motor_pos和imu_pos的变化方向
        // 如果方向相同，用加法；如果相反，用减法

        // 假设方向相同（需要实测验证）
        Gimbal.pitch.pitch_offset = motor_pos_init - imu_pos_init;

        // 或者，假设方向相反
        // Gimbal.pitch.pitch_offset = motor_pos_init + imu_pos_init;

        printf("=== Init Debug ===\n");
        printf("Motor_init: %.4f\n", motor_pos_init);
        printf("IMU_init: %.4f\n", imu_pos_init);
        printf("Offset: %.4f\n", Gimbal.pitch.pitch_offset);
